# ============================================
# Docker Compose 环境变量
# 复制本文件为 .env 并修改密码、密钥
# ============================================

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=请改成你自己的强密码
POSTGRES_DB=nexus

# JWT 签名密钥 - 必须改成随机长字符串！
# 生成方式: openssl rand -base64 64
JWT_SECRET=请改成随机64位字符串
