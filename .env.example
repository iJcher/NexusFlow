# ============================================
# Docker Compose 环境变量
# 复制本文件为 .env 并修改密码、密钥
# ============================================

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=请改成你自己的强密码
POSTGRES_DB=nexus

# JWT 签名密钥 - 必须改成随机长字符串！
# 生成方式: openssl rand -base64 64
JWT_SECRET=请改成随机64位字符串

# ============================================
# Skill 生成默认大模型（系统兜底，所有用户共享）
# 当前接的是 dogapi 中转：https://www.dogapi.cc
# 模型清单获取方式：
#   curl -H "Authorization: Bearer $TOKEN" https://www.dogapi.cc/v1/models
# ⚠️ MODEL_NAME 必须是 token 实际有权访问的模型，否则会 403
# ============================================
SKILL_DEFAULT_API_URL=https://www.dogapi.cc
SKILL_DEFAULT_API_KEY=请填写 dogapi 的 sk-xxx token
SKILL_DEFAULT_MODEL_NAME=gpt-5.4
SKILL_DEFAULT_DISPLAY_NAME=系统默认 (GPT-5.4)

# ============================================
# RAG 默认向量化模型（系统兜底，所有用户共享）
# 不配置时新用户会退到 TF-IDF 伪向量，召回质量很差
#
# 推荐：阿里云百炼 text-embedding-v4
#   - OpenAI 兼容协议，与 NEXUS 现有 EmbeddingService 100% 契合
#   - 1024 默认维度，性能/成本平衡最优
#   - 100 万 Token 免费额度（百炼开通后 90 天内）
#
# 申请 DashScope API Key：
#   https://help.aliyun.com/zh/model-studio/get-api-key
# 模型清单与定价：
#   https://help.aliyun.com/zh/model-studio/embedding
# ============================================
RAG_DEFAULT_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_DEFAULT_EMBEDDING_API_KEY=请填写阿里云百炼的 sk-xxx (DashScope key)
RAG_DEFAULT_EMBEDDING_MODEL_NAME=text-embedding-v4
