# 开发环境配置
# 浏览器实际请求路径：所有 /api 请求会被 vite dev server 代理转发
VITE_API_BASE_URL=/api

# vite proxy 转发目标
# - 本地全栈开发：http://localhost:30050（请同时把 STRIP_PREFIX 改成 true）
# - 本地前端 + 线上后端：http://39.106.185.151（STRIP_PREFIX 保持 false）
VITE_PROXY_TARGET=http://39.106.185.151

# 是否在转发时去掉 /api 前缀
# - true：直连本地 NestJS（NestJS 不带 /api 前缀）
# - false：转发到线上 nginx（线上 nginx 自己会处理 /api 前缀）
VITE_PROXY_STRIP_PREFIX=false
