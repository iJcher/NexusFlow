generator client {
  provider        = "prisma-client-js"
  // 启用 Postgres 扩展支持，用于声明 pgvector
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector 扩展：用于知识库 chunk 的向量检索（直接在 PG 内算 cosine，
  // 替代「全表 findMany 进 Node 算」的方案，从根本上解决 RAG 内存爆炸问题）
  extensions = [vector]
}

model FlowEntity {
  id               BigInt    @id
  ownerUserId      BigInt?
  displayName      String    @default("")
  flowType         Int       @default(0)
  description      String    @default("")
  configInfoForRun String?
  configInfoForWeb String?
  lastModified     DateTime? @updatedAt
  lastModifyBy     String?

  @@index([ownerUserId])
  @@index([flowType])
  @@map("FlowEntity")
}

model FlowLLMProviderEntity {
  id           BigInt  @id
  ownerUserId  BigInt?
  platformName String
  llmNames     String
  llmAPIUrl    String
  llmAPIKey    String

  @@index([ownerUserId])
  @@map("FlowLLMProviderEntity")
}

model FlowChatConversationEntity {
  conversationId   String   @id
  ownerUserId      BigInt?
  user             String
  flowId           BigInt
  title            String   @default("")
  isTop            Boolean  @default(false)
  messageCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  variables        String?

  @@index([ownerUserId, flowId, updatedAt])
  @@unique([conversationId, user])
  @@map("FlowChatConversationEntity")
}

model FlowChatMessageEntity {
  id               BigInt   @id
  ownerUserId      BigInt?
  user             String
  flowId           BigInt
  conversationId   String
  flowInstanceId   BigInt
  question         String   @default("")
  answer           String   @default("")
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  createdAt        DateTime @default(now())
  files            String?

  @@index([ownerUserId, flowId, conversationId, createdAt])
  @@index([user, conversationId, createdAt])
  @@map("FlowChatMessageEntity")
}

model UserEntity {
  id                BigInt    @id
  phoneNumber       String    @unique
  passwordHash      String
  passwordSalt      String
  nickName          String
  lastLoginIp       String    @default("")
  lastLoginTime     DateTime  @default(now())
  registerTime      DateTime  @default(now())
  source            String?
  isDeleted         Boolean   @default(false)
  isEnable          Boolean?  @default(true)
  lockoutEndDateUtc DateTime?
  lockoutEnabled    Boolean   @default(false)
  accessFailedCount Int?      @default(0)
  role              Int       @default(1)

  @@map("UserEntity")
}

// ==================== 组件模板库 ====================

model FlowTemplateEntity {
  id               BigInt   @id
  ownerUserId      BigInt?
  name             String
  description      String   @default("")
  flowType         Int      @default(0)
  category         String   @default("custom")
  tags             String   @default("[]")
  configInfoForRun String?
  configInfoForWeb String?
  isOfficial       Boolean  @default(false)
  createdBy        String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([ownerUserId])
  @@index([flowType])
  @@index([category])
  @@index([isOfficial])
  @@map("FlowTemplateEntity")
}

// ==================== RAG 知识库 ====================

model KnowledgeBaseEntity {
  id             BigInt   @id
  ownerUserId    BigInt?
  name           String
  description    String   @default("")
  createdBy      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  docCount       Int      @default(0)
  chunkCount     Int      @default(0)
  status         String   @default("active")
  embeddingModel String   @default("")
  chunkSize      Int      @default(500)
  chunkOverlap   Int      @default(50)
  chunkStrategy  String   @default("paragraph")

  documents KnowledgeDocumentEntity[]

  @@index([ownerUserId])
  @@index([createdBy])
  @@map("KnowledgeBaseEntity")
}

model KnowledgeDocumentEntity {
  id              BigInt   @id
  knowledgeBaseId BigInt
  fileName        String
  fileSize        Int      @default(0)
  fileType        String   @default("")
  content         String   @default("")
  chunkCount      Int      @default(0)
  status          String   @default("pending")
  errorMsg        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  knowledgeBase KnowledgeBaseEntity      @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        KnowledgeDocChunkEntity[]

  @@index([knowledgeBaseId])
  @@map("KnowledgeDocumentEntity")
}

model KnowledgeDocChunkEntity {
  id         BigInt @id
  documentId BigInt
  chunkIndex Int    @default(0)
  content    String @default("")
  // 旧字段：JSON 字符串形式的 embedding，保留作为兜底/回滚通道
  embedding  String @default("[]")
  // 新字段：pgvector 原生向量类型，1024 维（text-embedding-v4 默认维度）
  // Prisma 不支持 vector 原生 DSL，用 Unsupported 声明
  // 实际相似度查询走 $queryRawUnsafe + SQL operator <=> （cosine distance）
  embeddingVec Unsupported("vector(1024)")?
  tokenCount Int    @default(0)

  document KnowledgeDocumentEntity @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("KnowledgeDocChunkEntity")
}

model SkillEntity {
  id               BigInt   @id
  ownerUserId      BigInt
  flowId           BigInt
  name             String
  description      String   @default("")
  version          Int      @default(1)
  inputSchema      String   @default("{}")
  outputSchema     String   @default("{}")
  workflowSnapshot String
  filesJson        String   @default("{}")
  generationPrompt String   @default("")
  modelName        String   @default("")
  status           String   @default("generated")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([ownerUserId])
  @@index([flowId])
  @@map("SkillEntity")
}

model McpServerEntity {
  id          BigInt   @id
  ownerUserId BigInt
  name        String
  transport   String   @default("sse")
  endpoint    String   @default("")
  command     String   @default("")
  args        String   @default("[]")
  env         String   @default("{}")
  headers     String   @default("{}")
  toolsJson   String   @default("[]")
  lastSyncAt  DateTime?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([ownerUserId])
  @@map("McpServerEntity")
}
