# ============================================
# 后端环境变量示例 - 复制为 .env 并按需修改
# ============================================

# 服务监听端口
PORT=30050

# 运行模式: development | production
NODE_ENV=production

# ============================================
# 数据库 (PostgreSQL)
# ============================================
# 本地开发可用: postgresql://postgres:postgres@localhost:5432/nexus
# 生产环境（Docker Compose 内部网络）会用 service 名 postgres 作为 host
DATABASE_URL=postgresql://nexus:nexus_password_change_me@postgres:5432/nexus

# ============================================
# JWT 认证
# ============================================
# 生产环境务必改成随机长字符串！
# 生成方式: openssl rand -base64 64
JWT_SECRET=please-change-this-to-a-random-string-in-production
